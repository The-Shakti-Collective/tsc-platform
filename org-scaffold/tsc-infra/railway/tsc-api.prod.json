{
  "$schema": "https://railway.com/railway.schema.json",
  "$comment": "Reference for tsc-api-prod Railway service",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm db:generate && pnpm build && pnpm verify:dist && RAILWAY_DEPLOY_DIR=/app/deploy node scripts/create-deploy-bundle.mjs"
  },
  "deploy": {
    "startCommand": "node scripts/railway-start.mjs",
    "healthcheckPath": "/api/health/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "API_GLOBAL_PREFIX": "api"
      }
    }
  }
}
