# TSC Community (Next.js) — copy to apps/community/.env.local (never commit secrets)
# Next.js loads `.env.local` only (not repo root `.env`). See ../../ENVIRONMENT_GUIDE.md

# --- Auth (Clerk SSO + local stub) ---
# Server middleware: TSC_AUTH_STUB, CLERK_SECRET_KEY
# Client: NEXT_PUBLIC_* only
TSC_AUTH_STUB=true
NEXT_PUBLIC_AUTH_STUB=true
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stub user id for AuthTokenProvider (local dev)
NEXT_PUBLIC_STUB_USER_ID=stub-dev-user

# Production multi-domain SSO (optional)
# NEXT_PUBLIC_CLERK_IS_SATELLITE=true
# NEXT_PUBLIC_CLERK_DOMAIN=community.theshakticollective.in
# CLERK_SIGN_IN_URL=https://theshakticollective.in/sign-in

# --- API & URLs ---
# Platform API only — never set to api.coreknot.in or localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TSC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3002

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Dev mock UI (never true in production) ---
# NEXT_PUBLIC_USE_MOCK_DATA=true

# --- Error tracking (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
