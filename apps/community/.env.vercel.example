# TSC Community — Vercel (`tsc-platform-community`)
# Root Directory: apps/community · Framework: Next.js
# Copy values into Vercel Dashboard → Settings → Environment Variables
# NEVER use POSTHOG_API_KEY or POSTHOG_HOST — Community reads NEXT_PUBLIC_POSTHOG_* only.

# --- API (Platform only — not CoreKnot) ---
NEXT_PUBLIC_TSC_API_URL=https://api.theshakticollective.in/api
NEXT_PUBLIC_API_URL=https://api.theshakticollective.in/api

# --- App URLs ---
# Path deploy on apex (requires NEXT_PUBLIC_BASE_PATH=/community on Vercel):
NEXT_PUBLIC_BASE_PATH=/community
NEXT_PUBLIC_APP_URL=https://theshakticollective.in/community
NEXT_PUBLIC_WEBSITE_URL=https://theshakticollective.in
# Subdomain + Clerk satellite (if using community.theshakticollective.in):
# NEXT_PUBLIC_APP_URL=https://community.theshakticollective.in
# NEXT_PUBLIC_CLERK_IS_SATELLITE=true
# NEXT_PUBLIC_CLERK_DOMAIN=community.theshakticollective.in
# CLERK_SIGN_IN_URL=https://theshakticollective.in/sign-in

# --- Clerk (production: real keys, stub off) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/community/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/community/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/community/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/community/onboarding
TSC_AUTH_STUB=false
NEXT_PUBLIC_AUTH_STUB=false

# --- PostHog (client) — KEY is phc_…, HOST is https://us.i.posthog.com ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Observability (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
