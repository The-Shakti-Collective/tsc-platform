# Production OAuth / integration env — copy values to Render Dashboard (CoreKnot API service)
# Do NOT commit real secrets. See docs/GOOGLE_META_APP_VERIFICATION.md
# Production API host: read .cursor/production-hosts.local.json (never commit)

NODE_ENV=production
SERVER_URL=https://YOUR-PRODUCTION-API.onrender.com
APP_BASE_URL=https://YOUR-PRODUCTION-API.onrender.com
TRACKING_BASE_URL=https://YOUR-PRODUCTION-API.onrender.com

FRONTEND_URL=https://tsccoreknot.com
CLIENT_URL=https://tsccoreknot.com

# Redis (Render Key Value) — required for BullMQ workers in production
REDIS_URL=redis://YOUR-REDIS-INTERNAL-URL:6379

ALLOWED_DOMAIN=theshakticollective.in
ADMIN_EMAIL=REDACTED_ADMIN@example.com

# Google staff login (consider Internal OAuth user type in GCP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR-PRODUCTION-API.onrender.com/api/auth/google/callback

# YouTube artist analytics (External OAuth — requires Google verification)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-API.onrender.com/api/artists/auth/callback/youtube
YOUTUBE_REDIRECT_URI_PROD=https://YOUR-PRODUCTION-API.onrender.com/api/artists/auth/callback/youtube
YOUTUBE_API_KEY=

# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
# Do not rely on META_USER_TOKEN in production after App Review

# Meta Dashboard URLs to register:
# OAuth redirect:  https://tsccoreknot.com/oauth/meta/callback
# Webhook:         https://YOUR-PRODUCTION-API.onrender.com/api/webhooks/instagram
# Data deletion:   https://YOUR-PRODUCTION-API.onrender.com/api/webhooks/meta-data-deletion
