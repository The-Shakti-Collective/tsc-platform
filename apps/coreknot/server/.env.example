# CoreKnot CRM API (Express) — copy to apps/coreknot/server/.env (never commit secrets)
# Backend only — client vars live in apps/coreknot/client/.env.example → .env.local
# Load order (dev): this file, then repo root `.env` (DATABASE_URL/REDIS_URL). See ../../../ENVIRONMENT_GUIDE.md
# Local vs prod DB guide: docs/LOCAL_DEV_DATABASE.md

PORT=5000



# ============ DATABASE ============
# Production cutover (Neon primary): docs/migration/PRODUCTION-CUTOVER.md
# Validate: pnpm migrate:coreknot:verify-cutover --ping

# --- PRODUCTION PARALLEL-RUN (recommended first deploy to Neon) ---
# COREKNOT_POSTGRES_ENABLED=true
# COREKNOT_AUTH_STORE=postgres
# COREKNOT_TENANT_STORE=postgres
# COREKNOT_PROJECTS_STORE=postgres
# COREKNOT_TASKS_STORE=postgres
# COREKNOT_CRM_STORE=postgres
# COREKNOT_ARTISTS_STORE=postgres
# COREKNOT_DISABLE_GRIDFS_BACKUP=true
# BACKUP_DESTINATION=neon
# SUPABASE_SECONDARY_ENABLED=false
# LOGS_PRIMARY_SUPABASE=false
# MONGODB_URI_PROD=mongodb+srv://...   # keep during 30-day dual-write
# DATABASE_URL=postgresql://...@neon.tech/...?sslmode=require

# ETL (pnpm migrate:coreknot:p0): scripts load root .env then this file; Mongo keys here override root.

# --- Mongo (legacy primary — default until domain flags flip) ---
MONGODB_URI=mongodb://localhost:27017/taskmaster_local

# --- Postgres (Prisma / @tsc/database — migration target) ---
# Local Docker: same as root .env — pnpm infra:up
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community
# Neon dev branch: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Master switch — set false to disable all Prisma paths in CoreKnot server
# COREKNOT_POSTGRES_ENABLED=true

# Per-domain store: mongo (default) | postgres
# Pilot: auth/users — requires pnpm coreknot:migrate:export-users && pnpm coreknot:migrate:seed-auth
# COREKNOT_AUTH_STORE=mongo
# COREKNOT_AUTH_STORE=postgres

# Wave 1 P0 domains — require pnpm migrate:coreknot:p0:execute (ETL) first
# COREKNOT_PROJECTS_STORE=mongo
# COREKNOT_PROJECTS_STORE=postgres
# COREKNOT_TASKS_STORE=mongo
# COREKNOT_TASKS_STORE=postgres
# COREKNOT_CRM_STORE=mongo
# COREKNOT_CRM_STORE=postgres
# COREKNOT_TENANT_STORE=postgres
# Wave 1 artists read path — requires pnpm migrate:coreknot:p0:execute (Artist + SyncMapping)
# COREKNOT_ARTISTS_STORE=postgres

# Wave 2 P1 domains (default mongo) — data mirrored to ck_legacy_documents when postgres
# COREKNOT_MAIL_STORE=mongo
# COREKNOT_DATAHUB_STORE=mongo
# COREKNOT_ATTENDANCE_STORE=mongo
# COREKNOT_FINANCE_STORE=mongo
# COREKNOT_NEWSLETTER_STORE=mongo
# COREKNOT_INTEGRATIONS_STORE=mongo
# COREKNOT_GAMIFICATION_STORE=mongo
# COREKNOT_CALENDAR_STORE=mongo
# COREKNOT_NOTIFICATIONS_STORE=mongo

# Local all-postgres profile (Wave 3) — see docs/migration/LOCAL-READINESS-REPORT.md
# COREKNOT_POSTGRES_PRIMARY=true
# COREKNOT_MONGO_REQUIRED=false
# COREKNOT_DISABLE_GRIDFS_BACKUP=true
# BACKUP_DESTINATION=neon

# --- Local all-postgres block (uncomment together after ETL + auth seed) ---
# COREKNOT_POSTGRES_ENABLED=true
# COREKNOT_AUTH_STORE=postgres
# COREKNOT_TENANT_STORE=postgres
# COREKNOT_PROJECTS_STORE=postgres
# COREKNOT_TASKS_STORE=postgres
# COREKNOT_CRM_STORE=postgres
# COREKNOT_ARTISTS_STORE=postgres
# COREKNOT_MAIL_STORE=postgres
# COREKNOT_DATAHUB_STORE=postgres
# COREKNOT_ATTENDANCE_STORE=postgres
# COREKNOT_FINANCE_STORE=postgres
# COREKNOT_NEWSLETTER_STORE=postgres
# COREKNOT_INTEGRATIONS_STORE=postgres
# COREKNOT_GAMIFICATION_STORE=postgres
# COREKNOT_CALENDAR_STORE=postgres
# COREKNOT_NOTIFICATIONS_STORE=postgres

# Organizations / tenant context — requires legacy tenant seed (same export/seed as auth)
# COREKNOT_TENANT_STORE=mongo
# COREKNOT_TENANT_STORE=postgres

# Atlas production (ETL source) — cluster taskmaster_production
# Copy from Atlas → Connect → Drivers. Never commit real credentials.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/taskmaster_production

# Windows: SRV lookup (querySrv ECONNREFUSED) — use direct shard URI instead of mongodb+srv:
# MONGODB_URI=mongodb://USER:PASS@ac-xxxxx-shard-00-00.xxxxx.mongodb.net:27017/taskmaster_production?ssl=true&directConnection=true&authSource=admin
# Optional alias when keeping srv in MONGODB_URI for other tools:
# MONGODB_DIRECT_URI=mongodb://USER:PASS@ac-xxxxx-shard-00-00.xxxxx.mongodb.net:27017/taskmaster_production?ssl=true&directConnection=true&authSource=admin

# Connecting to taskmaster_production from local dev requires:
# ALLOW_PROD_DB_IN_DEV=true
# Atlas → Network Access → add your current public IP (or 0.0.0.0/0 for dev only)
# If login shows "Database temporarily unavailable", check GET http://localhost:5000/api/health
# (mongodb.state should be "connected"; if "disconnected", fix URI or IP allowlist and restart CRM)

# Production — used when NODE_ENV=production (Render API)
MONGODB_URI_PROD=mongodb+srv://REDACTED:REDACTED@REDACTED.example.com/



# Optional: explicit DB names for sync scripts (defaults below)

MONGODB_DB_LOCAL=taskmaster_local

MONGODB_DB_PROD=taskmaster_production



# Vercel Preview — set via Vercel dashboard env vars, not here

# VERCEL_ENV=preview → uses MONGODB_URI (taskmaster_local)

# VERCEL_ENV=production on API host → uses MONGODB_URI_PROD



# Prod → local sync mode default (full | operational). Operational skips CRM/Data Hub collections.
# SYNC_MODE=operational
# After operational sync, keep reconcile off locally:
DATA_HUB_RECONCILE_ENABLED=false

# Mail tracking from localhost: opt-in only — affects ENTIRE server DB connection when true
# When true, npm run dev connects to MONGODB_URI_PROD (production), not MONGODB_URI.
# Leave false for normal local development. Use TRACKING_BASE_URL for open/click pixels instead.
MAIL_USE_PROD_DB=false

# Log localhost office-IP bypass for attendance work-mode hint (dev only)
ATTENDANCE_DEBUG=false

# Lighthouse QA (optional): defaults to FRONTEND_URL on Render/production, localhost:4173 locally
# LH_BASE_URL=https://tsccoreknot.com
# LH_API_URL=https://YOUR-RENDER-SERVICE.onrender.com
# QA_PROBE_EMAIL_DOMAIN=theshakticollective.in



# Allow dev server to connect to a production-named DB (discouraged)

# ALLOW_PROD_DB_IN_DEV=false



# ============ AUTHENTICATION & SECURITY ============

JWT_SECRET=your_secure_secret_here
# 64-char hex — openssl rand -hex 32. Required on Render for OAuth/API token encryption.
ENCRYPTION_KEY=
JWT_EXPIRES_IN=7d
# Sliding inactivity window (JWT_EXPIRES_IN). Hard re-login cap from first login:
JWT_ABSOLUTE_MAX_DAYS=30
# Min minutes between Set-Cookie refreshes on activity (reduces mobile cookie churn):
JWT_REFRESH_MINUTES=60
# Override local dev default password (shared/defaultPassword.js fallback: 1Million#)
DEFAULT_SEED_PASSWORD=1Million#
NODE_ENV=development

# Local dev admin bypass — login page "Dev admin bypass" + POST /api/auth/dev-bypass (localhost only)
# Signs in as dev-admin@example.com (or DEV_BYPASS_EMAIL), NOT ADMIN_EMAIL.
# DEBUG_BYPASS=true
# DEBUG_BYPASS_TOKEN=bypass_token
# DEV_BYPASS_EMAIL=dev-admin@example.com

# Production signup restrictions — platform owner contact; not auto-seeded as "Dev Admin" in dev
ADMIN_EMAIL=admin@yourcompany.com
ALLOWED_DOMAIN=yourcompany.com
# REGISTRATION_DISABLED=true

# Comma-separated extra allowed browser origins (production API CORS)
# CORS_ALLOWED_ORIGINS=https://coreknot.in,https://www.coreknot.in,https://coreknot.theshakticollective.in
# Allow any *.vercel.app preview origin in production (default: false)
# CORS_ALLOW_VERCEL_PREVIEWS=true

# FRONTEND_URL=https://coreknot.in



# ============ OFFICE & ATTENDANCE ============

# Comma-separated IPs that count as in-office (IPv4 office egress + IPv6 if applicable + localhost for dev).
# Code merges OFFICE_PUBLIC_IP and OFFICE_IP_WHITELIST — set at least one on Render.

OFFICE_PUBLIC_IP=49.36.41.166,49.36.41.118
OFFICE_IP_WHITELIST=49.36.41.166,49.36.41.118,127.0.0.1,::1,::ffff:127.0.0.1



# ============ WEB PUSH NOTIFICATIONS ============

# Desktop notifications when ERP tab is closed (localhost works without HTTPS)

# Generate once: npx web-push generate-vapid-keys

# Set the same keys on Render/production; restart server after adding them.

VAPID_PUBLIC_KEY=

VAPID_PRIVATE_KEY=

VAPID_SUBJECT=mailto:redacted@example.com



# ============ QUEUES (mail campaigns + BullMQ) ============
# Production: REQUIRED for mail campaign dispatch (separate worker process).
# Empty locally = in-process batch fallback with warning (dev only).
# REDIS_URL=
# Local Docker/WSL Redis (pnpm infra:up → tsc-redis :6379):
# REDIS_URL=redis://127.0.0.1:6379
# Production (Upstash / Railway Key Value):
# REDIS_URL=rediss://default:TOKEN@endpoint.upstash.io:6379

# Mail campaign worker (Render Background Worker / Railway 2nd service)
# RUN_WORKERS=false   # web API default
# RUN_WORKERS=true    # workers/startWorkers.js only

# Batch size for coreknot.mail queue jobs (default 100)
# MAIL_CAMPAIGN_BATCH_SIZE=100
# Delay ms between sends within a batch (rate limit, default 150)
# MAIL_CAMPAIGN_SEND_DELAY_MS=150

# TSC NestJS API — passport/feed proxy target (start-stack starts :4000)
# TSC_API_URL=http://localhost:4000/api


HOLYSHEET_API_KEY=your_holysheet_api_key
# Artist Path questionnaire sheet (HolySheet API key for that linked spreadsheet)
HOLYSHEET_ARTIST_PATH_API_KEY=your_artist_path_holysheet_api_key
# Optional tab name when spreadsheet has multiple sheets (default: first sheet)
# HOLYSHEET_ARTIST_PATH_SHEET=Sheet1
# Booked calls: website → POST /api/webhooks/book-call (see docs/BOOKED_CALLS_CRM_DIRECT.md)
BOOK_CALL_WEBHOOK_SECRET=shared-with-tsc-website
# Website → POST /api/webhooks/artist-path (secret header or HMAC)
ARTIST_PATH_WEBHOOK_SECRET=shared-with-tsc-website
# Website → POST /api/webhooks/newsletter (X-Webhook-Secret only)
NEWSLETTER_WEBHOOK_SECRET=shared-with-tsc-website
# Website → POST /api/webhooks/masterclass-review (X-Webhook-Secret only)
MASTERCLASS_REVIEW_WEBHOOK_SECRET=shared-with-tsc-website
# Optional AiSensy campaign for artist-path confirmation WhatsApp
# AISENSY_ARTIST_PATH_CAMPAIGN=Confirmation TSC

EXLY_API_KEY=your_exly_api_key

# Public API base — used for OAuth callbacks when localhost env vars are set (Render)
# SERVER_URL=https://YOUR-PRODUCTION-API
# APP_BASE_URL=https://YOUR-PRODUCTION-API

# Google OAuth (staff login + Calendar/Drive)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/auth/google/callback

# YouTube OAuth (artist analytics — separate GCP OAuth client recommended)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/artists/auth/callback/youtube
# YOUTUBE_REDIRECT_URI_PROD=https://YOUR-PRODUCTION-API/api/artists/auth/callback/youtube
# YOUTUBE_API_KEY=

# Meta / Instagram (artist analytics)
# META_APP_ID=
# META_APP_SECRET=
# META_VERIFY_TOKEN=your_random_verify_string
# META_WEBHOOK_VERIFY_TOKEN=          # optional alias for META_VERIFY_TOKEN
# META_DEFAULT_PAGE_ID=               # optional fallback
# META_DEFAULT_IG_ID=                 # optional fallback
# META_USER_TOKEN=                    # dev fallback only — remove after App Review

# Frontend origin for Meta OAuth redirect (Vercel)
# CLIENT_URL=https://tsccoreknot.com
# FRONTEND_URL=https://tsccoreknot.com

# Spotify artist OAuth
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-API/api/artists/auth/callback/spotify

# Google Service Account (Sheets webhooks — server-to-server, not user OAuth)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=tsc-newsletter@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEET_ID=

# Full verification guide: docs/GOOGLE_META_APP_VERIFICATION.md
# Pre-flight check (admin): GET /api/integrations/oauth-readiness

YOUTUBE_API_KEY=your_youtube_api_key



# ============ WEBHOOK SECRETS ============
# HMAC: X-Webhook-Signature: sha256=<hmac-sha256-hex of raw JSON body>
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# EXLY_WEBHOOK_SECRET=

# Artist enquiry form — required in production (plain header X-Webhook-Secret)
ARTIST_ENQUIRY_WEBHOOK_SECRET=shared-with-tsc-website

# Meta/Instagram webhook signature verification (required in production)
# META_APP_SECRET=
# META_VERIFY_TOKEN=

# ============ ARTIST ENQUIRY WEBHOOK (public /query form) ============

# Optional JSON map: lowercase artist label → project name (ALL CAPS storage)

# ARTIST_ENQUIRY_PROJECT_MAP={"yugm":"YUGM","harshad & duhita":"HARSHAD DUHITA"}

# Fallback project name when artist label does not match

# ARTIST_ENQUIRY_FALLBACK_PROJECT_NAME=YUGM

# Songstats enterprise API (no fallback in code — must be set for artist stats)
# SONGSTATS_API_KEY=



# ============ BACKUP CONFIGURATION ============

# Daily production backup (Render cron — 12:01 AM IST / 18:31 UTC)

# Backups read ONLY from MONGODB_URI_PROD — never from local MONGODB_URI

BACKUP_ENABLED=true

BACKUP_RETENTION_COUNT=2

MONGODB_BACKUP_DB=taskmaster_backups

BACKUP_NOTIFY_EMAIL=

BACKUP_FROM_EMAIL=noreply@theshakticollective.in

# Uses ADMIN_EMAIL when BACKUP_NOTIFY_EMAIL is empty

# BACKUP_FROM_EMAIL must use a Resend-verified domain (not sandbox@taskmaster.io)



# Optional: force USD→INR rate for local testing (skips live Frankfurter API)

# USD_INR_RATE_OVERRIDE=85



# ============ SUPABASE SECONDARY STORE (deprecated — use Neon) ============
# Legacy ops mirror. Default OFF. Do not enable for new deployments.
# SUPABASE_SECONDARY_ENABLED=false
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_SECRET_KEY=alias for service role (same value)
# SUPABASE_DB_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres  # local/scripts only (IPv6)
# SUPABASE_PG_MODE=rest   # auto on Render — use PostgREST over HTTPS (IPv4)
# Session pooler (optional if IPv4 direct pg needed): aws-0-[region].pooler.supabase.com:5432
# SUPABASE_BACKUP_BUCKET=taskmaster-backups
# Where production snapshots go when widget/cron runs backup (default: supabase when configured)
# BACKUP_DESTINATION=supabase
# BACKUP_DESTINATION=mongo
# BACKUP_DESTINATION=both
# LOGS_PRIMARY_SUPABASE=true   # reads/writes system logs via Supabase when enabled (default true)
# MONGO_LOG_ARCHIVE=false      # optional cold archive of logs into Mongo TTL collections (90d)
# PERSIST_SYSTEM_LOGS=true     # enable system log persistence (Supabase primary when configured)
# Setup: npm run supabase:setup && npm run supabase:backfill && npm run supabase:health
# Audit: npm run audit:data-topology
# Cold TTL: npm run mongo:ensure-cold-ttl



# ============ OBJECT STORAGE (Cloudflare R2) ============
# Required for finance docs, mail templates, campaign attachments in production.
# Validate: npm run storage:verify-r2 (from this directory)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=tsc-assets-prod
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://assets.theshakticollective.in
# UploadThing fallback when R2 unset (legacy — avoid in production):
# UPLOADTHING_TOKEN=
# UPLOADTHING_SECRET=


# ============ OBSERVABILITY (optional — set in Render / Vercel dashboards) ============

# Sentry error tracking + structured logs (requires @sentry/node >= 9.41.0)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=coreknot@1.0.2
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Verify: node scripts/sentry-dsn-verify.js

# BetterStack uptime heartbeat (API web service only — pings every 60s)
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/xxxxx

# PostHog server-side (optional — client uses VITE_POSTHOG_KEY)
# POSTHOG_PROJECT_TOKEN=
# DD_API_KEY=
# DD_SITE=datadoghq.com
# DD_ENV=production
# DD_SERVICE=coreknot-api
# DD_VERSION=1.0.2
# DD_PROFILING_ENABLED=false

