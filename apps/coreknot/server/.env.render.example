# LEGACY — Render environment checklist (archived 2026-06-15)
# Deploy authority: Railway — see railway.toml and docs/DEPLOYMENT.md
# Copy NAMES to Render Dashboard only if rolling back from archive; never commit real values.
# Local mirror: server/.env.render (gitignored)

# Core
NODE_ENV=production
PORT=5000
MONGODB_URI=
MONGODB_URI_PROD=
JWT_SECRET=
ENCRYPTION_KEY=
JWT_EXPIRES_IN=7d
JWT_ABSOLUTE_MAX_DAYS=30
JWT_REFRESH_MINUTES=60
ADMIN_EMAIL=
ALLOWED_DOMAIN=

# URLs (API host — same origin for tracking/OAuth on Render)
APP_BASE_URL=https://YOUR-SERVICE.onrender.com
SERVER_URL=https://YOUR-SERVICE.onrender.com
TRACKING_BASE_URL=https://YOUR-SERVICE.onrender.com
# Redis (Key Value) for BullMQ — maxmemoryPolicy must be noeviction on Render
# REDIS_URL=redis://red-xxxxxxxx:6379
FRONTEND_URL=https://your-frontend-domain.com
CLIENT_URL=https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=

# Vercel only (not Render) — see docs/DEPLOY_ENV.md
# RENDER_API_PROXY_URL=https://YOUR-SERVICE.onrender.com

# Platform user IDs → prefer Admin → Users → Platform roles in the app
# Optional bootstrap if DB empty:
# ROOT_ADMIN_USER_IDS=
# PLATFORM_OWNER_USER_ID=

# Integrations — fill from your secret store
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
RESEND_API_KEY=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
# ...see server/.env.example for full list

# Supabase secondary store (backups, logs, mail rollups, CRM snapshots)
SUPABASE_SECONDARY_ENABLED=true
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
SUPABASE_BACKUP_BUCKET=taskmaster-backups

# Observability (optional)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# DD_API_KEY=
# DD_SITE=datadoghq.com
# DD_ENV=production
# DD_SERVICE=coreknot-api
