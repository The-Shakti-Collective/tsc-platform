# CoreKnot Railway — API + worker env template (non-secrets)
# Copy values into Railway Dashboard for BOTH services unless noted.
# See docs/FOUNDER-COREKNOT-LAUNCH.md for step-by-step setup.

# --- Secrets (Dashboard only — never commit) ---
# DATABASE_URL=postgresql://...@neon.tech/...
# REDIS_URL=rediss://...@upstash.io
# JWT_SECRET=          # openssl rand -base64 48
# ENCRYPTION_KEY=      # openssl rand -hex 32
# Clerk cutover (client Vercel): VITE_CLERK_PUBLISHABLE_KEY=pk_live_… from Clerk Dashboard → API Keys
# Platform API webhooks (Railway tsc-api): CLERK_SECRET_KEY, CLERK_WEBHOOK_SECRET (whsec_… from Webhooks → Signing secret)
# RESEND_API_KEY=re_...
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# SENTRY_DSN=...
# POSTHOG_API_KEY=...
# BETTERSTACK_HEARTBEAT_URL=...

NODE_ENV=production
PORT=5000

# Postgres-primary (Wave 3 — no Mongo required)
COREKNOT_POSTGRES_ENABLED=true
COREKNOT_POSTGRES_PRIMARY=true
COREKNOT_MONGO_REQUIRED=false

# P0 stores
COREKNOT_AUTH_STORE=postgres
COREKNOT_TENANT_STORE=postgres
COREKNOT_PROJECTS_STORE=postgres
COREKNOT_TASKS_STORE=postgres
COREKNOT_CRM_STORE=postgres
COREKNOT_ARTISTS_STORE=postgres

# P1 stores (ck_legacy_documents)
COREKNOT_MAIL_STORE=postgres
COREKNOT_DATAHUB_STORE=postgres
COREKNOT_ATTENDANCE_STORE=postgres
COREKNOT_FINANCE_STORE=postgres
COREKNOT_NEWSLETTER_STORE=postgres
COREKNOT_INTEGRATIONS_STORE=postgres
COREKNOT_GAMIFICATION_STORE=postgres
COREKNOT_CALENDAR_STORE=postgres
COREKNOT_NOTIFICATIONS_STORE=postgres
COREKNOT_CUSTOMIZATION_STORE=postgres

# Backups / legacy off
COREKNOT_DISABLE_GRIDFS_BACKUP=true
BACKUP_DESTINATION=neon
SUPABASE_SECONDARY_ENABLED=false
LOGS_PRIMARY_SUPABASE=false
PERSIST_SYSTEM_LOGS=true

# Service role — set per Railway service
# API:  RUN_WORKERS=false
# Worker: RUN_WORKERS=true
RUN_WORKERS=false

# Client / OAuth / mail tracking
FRONTEND_URL=https://coreknot.in.
ALLOWED_DOMAIN=theshakticollective.in

# CORS — CoreKnot Vercel hosts (tsc-coreknot*.vercel.app) always allowed in code.
# Optional: allow other *.vercel.app preview origins in production.
# CORS_ALLOW_VERCEL_PREVIEWS=true
# Extra explicit origins (comma-separated):
# CORS_ALLOWED_ORIGINS=https://tsc-coreknot.vercel.app,https://coreknot.in

# Object storage — Cloudflare R2 (API + worker; set on both Railway services)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=tsc-assets-prod
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://assets.theshakticollective.in
