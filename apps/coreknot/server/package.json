{
  "name": "@tsc/coreknot-server",
  "version": "1.0.7",
  "description": "Enterprise Work Management API",
  "main": "server.js",
  "scripts": {
    "typecheck": "node -e \"process.exit(0)\"",
    "build": "cd ../client && npm install && npm run build",
    "start": "node server.js",
    "start:workers": "node workers/startWorkers.js",
    "predev": "node scripts/freePort.js 5000 --wait",
    "dev": "nodemon server.js",
    "test": "node scripts/runJest.js",
    "postinstall": "node scripts/linkJestSourceMap.js",
    "test:migration-stores": "jest --config jest.migration.config.js",
    "sync-db": "node scripts/syncProdToLocal.js --yes",
    "sync-finance-to-prod": "node scripts/syncFinanceToProd.js",
    "sync-email-campaigns:dry-run": "node scripts/syncEmailCampaignsToProd.js --dry-run",
    "sync-email-campaigns:prod": "node scripts/syncEmailCampaignsToProd.js --yes",
    "import-finance": "node scripts/importInvoices.js --skip-ocr",
    "import-finance:fresh": "node scripts/importInvoices.js --fresh --skip-ocr",
    "backup:daily": "node scripts/runDailyBackup.js",
    "seed:music-calendar": "node scripts/seedMusicContentCalendar.js --year=2026",
    "seed:music-calendar:prod": "node scripts/seedMusicContentCalendar.js --year=2026 --prod",
    "reconcile:datahub:prod": "node scripts/reconcileDataHub.js --prod --full",
    "seed:prod-content": "node scripts/seedProductionContent.js",
    "reset-weak-passwords": "node scripts/resetWeakUserPasswords.js",
    "reset-weak-passwords:local:apply": "node scripts/resetWeakUserPasswords.js --apply",
    "reset-weak-passwords:prod": "node scripts/resetWeakUserPasswords.js --prod",
    "reset-weak-passwords:prod:apply": "node scripts/resetWeakUserPasswords.js --prod --apply",
    "normalize:person-data": "node scripts/normalizePersonData.js --dry-run",
    "normalize:person-data:execute": "node scripts/normalizePersonData.js --execute",
    "repair:lead-phones": "node scripts/repairCorruptPhones.js",
    "qa:audit": "node scripts/qaAuditReport.js",
    "qa:audit:prod": "node scripts/qaAuditReport.js --prod",
    "qa:cleanup": "node scripts/qaFullCleanup.js",
    "qa:cleanup:prod": "node scripts/qaFullCleanup.js --prod",
    "storage:audit": "node scripts/atlasStorageCleanup.js --dry-run",
    "storage:cleanup": "node scripts/atlasStorageCleanup.js --execute",
    "storage:cleanup:backups": "node scripts/atlasStorageCleanup.js --execute --only=backups --db=backups",
    "repair:phones": "node scripts/repairCorruptPhones.js --local",
    "repair:phones:prod": "node scripts/repairCorruptPhones.js --prod",
    "repair:phones:all": "node scripts/repairCorruptPhones.js --local && node scripts/repairCorruptPhones.js --prod",
    "purge:local-only-collections": "node scripts/purgeLocalOnlyCollections.js --execute",
    "purge:local-only-collections:dry-run": "node scripts/purgeLocalOnlyCollections.js --dry-run",
    "render:ops-fix": "node scripts/applyRenderOpsFixes.js",
    "render:ops-fix:deploy": "node scripts/applyRenderOpsFixes.js --deploy",
    "supabase:setup": "node scripts/supabaseSetup.js",
    "supabase:health": "node scripts/supabaseHealthCheck.js",
    "audit:data-topology": "node scripts/auditDataTopology.js",
    "audit:data-topology:purge-dry-run": "node scripts/auditDataTopology.js --purge-dry-run",
    "mongo:ensure-cold-ttl": "node scripts/ensureColdArchiveTtlIndexes.js",
    "supabase:backfill": "node scripts/supabaseBackfill.js",
    "supabase:migrate": "node scripts/supabaseFastMigrate.js --prod",
    "supabase:migrate:local": "node scripts/supabaseFastMigrate.js",
    "backup:verify-supabase": "node scripts/verifySupabaseBackup.js"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.1.6",
    "@coreknot/contracts": "workspace:*",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^9.47.1",
    "@supabase/supabase-js": "^2.108.1",
    "@trigger.dev/sdk": "^4.4.0",
    "@tsc/database": "workspace:*",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie": "^0.7.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.1.0",
    "dd-trace": "^5.106.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "geoip-lite": "^1.2.2",
    "googleapis": "^171.4.0",
    "helmet": "^6.0.1",
    "imap-simple": "^1.6.3",
    "ioredis": "^5.11.0",
    "ipaddr.js": "^2.4.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.0",
    "juice": "^11.1.1",
    "mailparser": "^3.9.8",
    "mongodb": "^6.20.0",
    "mongoose": "^7.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-ical": "^0.26.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "svix": "^1.94.0",
    "tesseract.js": "^7.0.0",
    "uploadthing": "^7.7.4",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "buffer-from": "^1.1.2",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.14",
    "source-map": "0.5.7",
    "supertest": "^7.2.2"
  }
}
