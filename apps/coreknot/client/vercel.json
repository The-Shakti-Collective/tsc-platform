{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.coreknot.in/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://api.coreknot.in/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "cd ../../.. && pnpm exec turbo run build --filter=@tsc/coreknot-client",
  "installCommand": "cd ../../.. && HUSKY=0 pnpm install --frozen-lockfile"
}
