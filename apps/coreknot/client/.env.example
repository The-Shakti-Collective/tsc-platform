# CoreKnot client (Vite) — copy to .env.local (never commit secrets)
# Setup: copy root .env via scripts/setup.ps1, or copy this file manually.
# Full reference: ../../.env.example and ../../ENVIRONMENT_GUIDE.md

# --- API ---
# Dev: Vite proxies /api → localhost:4000; VITE_API_URL optional
VITE_API_URL=http://localhost:4000
VITE_TSC_API_URL=http://localhost:4000/api

# --- Auth (Clerk — same publishable key as Community/Website) ---
# Local dev: leave empty or placeholder — stub mode auto-enables in non-prod builds
VITE_CLERK_PUBLISHABLE_KEY=
# Optional explicit stub flag (otherwise inferred from placeholder key)
# VITE_AUTH_STUB=true

# --- Analytics (optional) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Error tracking (optional — no-ops when unset) ---
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Vercel production (set in project dashboard / `vercel env`) ---
# VITE_API_URL=https://api.theshakticollective.in
# VITE_TSC_API_URL=https://api.theshakticollective.in/api
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# VITE_AUTH_STUB=false
