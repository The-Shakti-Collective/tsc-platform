# CoreKnot client (Vite) — copy to apps/coreknot/client/.env.local (never commit secrets)
# Vite exposes only VITE_* to the browser. CRM API :5000; TSC API :4000. See ../../../ENVIRONMENT_GUIDE.md

# --- CRM API (session cookies — use same-origin /api proxy in dev) ---
# Do NOT point VITE_API_URL at :4000 — breaks CRM auth cookies
VITE_API_URL=http://localhost:5000

# --- TSC ecosystem API (@tsc/api on :4000 — passport, feed, booking) ---
VITE_TSC_API_URL=http://localhost:4000/api

# --- Clerk SSO (optional — stub when unset in dev) ---
# Clerk Dashboard → API Keys → Publishable key (same pk_test_* as Platform frontends)
VITE_CLERK_PUBLISHABLE_KEY=
# VITE_AUTH_STUB=true

# --- Dev admin bypass (Vite dev only; omitted from production builds) ---
# Shown when import.meta.env.DEV unless disabled:
# VITE_ENABLE_DEV_BYPASS=false

# --- Uploads (optional) ---
# VITE_UPLOADTHING_URL=http://localhost:5000/api/uploadthing

# --- Platform owner (optional — task review UI) ---
# VITE_PLATFORM_OWNER_EMAIL=

# --- Feature flags (optional) ---
# VITE_MAIL_ENGINE_V2=true
# VITE_SHOW_LOG_SANDBOX=true

# --- Dev tooling (optional — never set on Vercel production) ---
# VITE_AGENTATION_ENDPOINT=http://localhost:4747

# --- TSC public website (booking form links in CRM) ---
# Local dev: http://localhost:3002 — production: https://theshakticollective.in
VITE_TSC_WEBSITE_URL=http://localhost:3002

# --- Observability (optional — set in Vercel Dashboard or .env.local) ---
# SDK keys — required for live capture + to clear widget badges
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=coreknot@1.0.0
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_PROJECT_ID=
# Dashboard deep-links (public URLs only — no API keys)
# VITE_SENTRY_ORG_URL=https://sentry.io/organizations/the-shakti-collective/
# VITE_POSTHOG_PROJECT_URL=https://us.posthog.com/project/YOUR_PROJECT_ID
# VITE_BETTERSTACK_DASHBOARD_URL=https://uptime.betterstack.com/
# Datadog RUM is optional elsewhere (see docs/coreknot-observability-setup.md) — not shown on dashboard widget

# --- Production (Vercel Dashboard → Production only) ---
# VITE_API_URL=https://YOUR-PRODUCTION-CRM-API
# RENDER_API_PROXY_URL=https://YOUR-PRODUCTION-CRM-API
