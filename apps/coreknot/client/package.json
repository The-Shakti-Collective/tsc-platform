{
  "name": "@tsc/coreknot-client",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "postinstall": "node scripts/generateVercelConfig.cjs",
    "prebuild": "node scripts/generateVercelConfig.cjs && node scripts/generate-pwa-icons.mjs",
    "build": "node scripts/generateVercelConfig.cjs && vite build",
    "prevercel-build": "node scripts/generateVercelConfig.cjs",
    "vercel-build": "npm run build",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "lint": "eslint . --max-warnings 9999",
    "typecheck": "node -e \"process.exit(0)\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "lighthouse": "node scripts/lighthouse-audit.mjs",
    "lighthouse:public": "node scripts/lighthouse-audit.mjs --public-only",
    "lighthouse:ci": "node scripts/lighthouse-audit.mjs --public-only --min-a11y=90",
    "lighthouse:prod": "node scripts/lighthouse-audit.mjs --prod",
    "lighthouse:loop": "node scripts/lighthouse-loop.mjs",
    "lighthouse:loop:public": "node scripts/lighthouse-loop.mjs --public-only",
    "lighthouse:report": "node scripts/lighthouse-report-only.mjs"
  },
  "dependencies": {
    "@coreknot/contracts": "workspace:*",
    "@datadog/browser-rum": "^6.33.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^9.47.1",
    "@tailwindcss/vite": "^4.0.0-alpha.14",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.26",
    "@types/papaparse": "^5.5.2",
    "@uploadthing/react": "^7.3.3",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.3.4",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.10.0",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.257.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.78.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.9.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.0.0-alpha.14",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^3.2.6",
    "agentation": "^3.0.2",
    "chrome-launcher": "^1.2.1",
    "eslint": "^8.34.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.0",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.8.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
