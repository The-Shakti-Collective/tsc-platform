{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "cd ../../.. && pnpm exec turbo run build --filter=@tsc/coreknot-client",
  "installCommand": "cd ../../.. && HUSKY=0 pnpm install --frozen-lockfile"
}
