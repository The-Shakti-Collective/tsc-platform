{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "node scripts/vercelBuild.cjs",
  "installCommand": "node scripts/vercelInstall.cjs"
}
