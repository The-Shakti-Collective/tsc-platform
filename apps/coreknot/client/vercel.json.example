{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://YOUR-RENDER-SERVICE.onrender.com/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && npm install"
}
