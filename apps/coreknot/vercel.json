{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.coreknot.in/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://api.coreknot.in/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://api.coreknot.in",
      "RENDER_API_PROXY_URL": "https://api.coreknot.in",
      "COREKNOT_DEPLOY": "true"
    }
  },
  "framework": null,
  "outputDirectory": null,
  "buildCommand": "node scripts/vercelBuildOutput.cjs",
  "installCommand": "echo coreknot-install-via-build"
}
