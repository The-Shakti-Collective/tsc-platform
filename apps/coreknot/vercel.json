{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.coreknot.in/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://api.coreknot.in/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run vercel-build",
  "installCommand": "HUSKY=0 node scripts/generateVercelConfig.cjs && npm install"
}
