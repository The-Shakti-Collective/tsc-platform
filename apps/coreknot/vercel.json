{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.coreknot.in/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://api.coreknot.in/socket.io/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "node scripts/vercelBuild.cjs",
  "installCommand": "node scripts/vercelInstall.cjs"
}
