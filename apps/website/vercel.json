{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "regions": ["bom1"],
  "redirects": [
    { "source": "/tscacademy", "destination": "/academy", "permanent": true },
    { "source": "/tscacademy/ambassador", "destination": "/academy/ambassador", "permanent": true },
    { "source": "/resources", "destination": "/insights", "permanent": true },
    { "source": "/ip", "destination": "/stories", "permanent": true },
    { "source": "/artist", "destination": "/query", "permanent": false },
    { "source": "/contact", "destination": "/about", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/community",
      "destination": "https://tsc-platform-community-pearl.vercel.app/community"
    },
    {
      "source": "/community/:match*",
      "destination": "https://tsc-platform-community-pearl.vercel.app/community/:match*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
