# TSC Website (Next.js) — copy to apps/website/.env.local (never commit secrets)
# Next.js loads `.env.local` only (not repo root `.env`). See ../../ENVIRONMENT_GUIDE.md

# --- Auth (Clerk SSO + local stub) ---
TSC_AUTH_STUB=true
NEXT_PUBLIC_AUTH_STUB=true
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Site & API URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3002
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3000
NEXT_PUBLIC_ARTIST_PATH_URL=https://theartistpath.in
# Platform API only — never set to api.coreknot.in or localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TSC_API_URL=http://localhost:4000/api

# --- Public API (optional — server-side fetch to TSC API) ---
# TSC_PUBLIC_API_KEY=

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Website contact → Platform API inquiry (server-side route) ---
# Must match apps/api WEBSITE_CONTACT_SECRET and TSC_DEFAULT_ORG_ID
TSC_API_URL=http://localhost:4000/api
WEBSITE_CONTACT_SECRET=
TSC_DEFAULT_ORG_ID=seed_org_dev_stub

# --- Error tracking (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
