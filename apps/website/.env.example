# TSC Website (Vite static MPA) — copy to apps/website/.env.local

# --- Vite client (optional) ---
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=

# --- Vercel serverless /api/* proxies → Platform API ---
TSC_API_URL=http://localhost:4000
PLATFORM_API_URL=http://localhost:4000
WEBSITE_PUBLIC_API_SECRET=shared-website-bff-secret
ARTIST_PATH_WEBHOOK_SECRET=

# --- Public links ---
VITE_WHATSAPP_COMMUNITY_URL=
