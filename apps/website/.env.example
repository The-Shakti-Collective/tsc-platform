# TSC Website (Next.js) — copy to .env.local (never commit secrets)
# Setup: copy root .env via scripts/setup.ps1, or copy this file manually.
# Full reference: ../../.env.example and ../../ENVIRONMENT_GUIDE.md

# --- Auth (Clerk SSO) ---
TSC_AUTH_STUB=true
NEXT_PUBLIC_AUTH_STUB=true
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- API / site ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TSC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Error tracking (optional — no-ops when unset) ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
