{
  "name": "@tsc/website",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3002",
    "build": "tsx scripts/export-site-data.mjs && node scripts/generate-pages.mjs && vite build",
    "restore:harshadduhita": "node scripts/restore-harshadduhita-wix.mjs",
    "preview": "vite preview --port 3002",
    "export-data": "tsx scripts/export-site-data.mjs",
    "generate-pages": "node scripts/generate-pages.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@sentry/browser": "^10.57.0",
    "posthog-js": "^1.232.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vercel/node": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
