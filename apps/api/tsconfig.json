{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@tsc/database/client": ["../../packages/database/dist/client"],
      "@tsc/contracts/*": ["../../packages/contracts/dist/*"],
      "@tsc/types": ["../../packages/types/dist/index"],
      "@tsc/types/*": ["../../packages/types/dist/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}


