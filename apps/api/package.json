{
  "name": "@tsc/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "openapi:export": "nest build && node dist/generate-openapi.js"
  },
  "dependencies": {
    "@clerk/backend": "^1.25.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@sentry/nestjs": "^10.57.0",
    "@tsc/analytics": "workspace:*",
    "@tsc/constants": "workspace:*",
    "@tsc/contracts": "workspace:*",
    "@tsc/database": "workspace:*",
    "@tsc/permissions": "workspace:*",
    "@tsc/projects": "workspace:*",
    "@tsc/tasks": "workspace:*",
    "@tsc/types": "workspace:*",
    "@tsc/workspace": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.0",
    "posthog-node": "^5.37.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.26",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.9.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
