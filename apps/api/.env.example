# TSC API (NestJS) — copy to apps/api/.env (never commit secrets)
# Shared infra: repo root `.env` (DATABASE_URL, REDIS_URL) — loaded after this file by run-api-dev.ps1
# Full matrix: ../../ENVIRONMENT_GUIDE.md

# --- Core ---
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- Database (required) — match root `.env` or set here ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community

# --- Redis (optional — empty = stub queue mode) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Clerk + local stub) ---
# Local: TSC_AUTH_STUB=true or leave CLERK_SECRET_KEY empty/placeholder
CLERK_SECRET_KEY=
# Clerk Dashboard → Webhooks → Signing secret (Svix). Endpoint: POST /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=
TSC_AUTH_STUB=true
TSC_STUB_USER_ID=stub-dev-user
TSC_ADMIN_USER_IDS=

# --- Website contact → Inquiry pipeline ---
# Org that receives public website contact submissions (see seed_org_dev_stub or prod org id)
TSC_DEFAULT_ORG_ID=
# Shared secret — Website sends X-Website-Contact-Secret header to POST /api/public/inquiries/contact
WEBSITE_CONTACT_SECRET=

# --- Public API rate limiting (requests/min per IP on unauthenticated routes) ---
TSC_PUBLIC_RATE_LIMIT_PER_MIN=60

# --- CoreKnot legacy JWT bridge (optional) ---
# COREKNOT_JWT_SECRET=
# COREKNOT_JWT_BRIDGE=false
# COREKNOT_DEFAULT_ORG_ID=
# JWT_ABSOLUTE_MAX_DAYS=30

# --- Platform API boundary (CoreKnot compat sunset) ---
# Disable CoreKnot legacy route aliases on Platform API in production (default: off when NODE_ENV=production)
# PLATFORM_COREKNOT_COMPAT_ENABLED=false

# --- CoreKnot sync outbound (optional) ---
# COREKNOT_SYNC_URL=http://localhost:5000/api/sync
# COREKNOT_API_URL=http://localhost:5000
# COREKNOT_SYNC_SECRET=

# --- Public links in emails / passports ---
TSC_PUBLIC_URL=http://localhost:3000

# --- Observability (optional — no-ops when unset) ---
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
BETTERSTACK_HEARTBEAT_URL=

# --- Search (optional — Typesense) ---
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PROTOCOL=https
TYPESENSE_PORT=443

# --- Object storage (optional — Cloudflare R2) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# --- Payment stubs (optional) ---
STRIPE_KEY=
RAZORPAY_KEY=
CASHFREE_KEY=

# --- Integration readiness probes (optional) ---
# GOOGLE_CLIENT_ID=
# META_APP_ID=
# SPOTIFY_CLIENT_ID=
# YOUTUBE_CLIENT_ID=
# RESEND_API_KEY=
# DISTROKID_API_KEY=

# --- AI (optional) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- OpenAPI export (optional) ---
# OPENAPI_EXPORT_ON_BOOT=true
# OPENAPI_EXPORT_PATH=apps/api/openapi/tsc-api.openapi.json
