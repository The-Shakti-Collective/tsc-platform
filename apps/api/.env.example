# TSC API (NestJS) — copy to .env (never commit secrets)
# Full reference: ../../.env.example and ../../ENVIRONMENT_GUIDE.md

# --- Core ---
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- Database (required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community

# --- Redis (optional — empty = stub queue mode) ---
# Local dev: redis://localhost:6379 (Docker compose / pnpm start:infra)
REDIS_URL=redis://localhost:6379
# Production (Railway): set REDIS_URL in service Variables — do not commit real URL
# Upstash: rediss://default:<TOKEN>@<endpoint>.upstash.io:6379
# Railway Redis plugin: redis://default:<password>@<host>.railway.internal:<port>
# REDIS_URL=<Railway or Upstash Redis URL>

# --- Clerk (required in production) ---
# Local dev: set TSC_AUTH_STUB=true or leave CLERK_SECRET_KEY empty/placeholder
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
TSC_AUTH_STUB=true
TSC_STUB_USER_ID=stub-dev-user
TSC_ADMIN_USER_IDS=

# --- Observability (optional — no-ops when unset) ---
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
BETTERSTACK_HEARTBEAT_URL=

# --- Search (optional — Typesense) ---
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PROTOCOL=https
TYPESENSE_PORT=443

# --- Object storage (optional — Cloudflare R2) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# --- Integrations (optional) ---
TSC_PUBLIC_URL=http://localhost:3000
COREKNOT_SYNC_URL=
COREKNOT_SYNC_SECRET=
STRIPE_KEY=
RAZORPAY_KEY=
CASHFREE_KEY=
