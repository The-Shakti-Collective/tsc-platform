{
    "name":  "tsc-platform",
    "private":  true,
    "workspaces":  [
                       "apps/*",
                       "apps/coreknot/client",
                       "apps/coreknot/server",
                       "apps/coreknot/shared/contracts",
                       "packages/*",
                       "e2e"
                   ],
    "scripts":  {
                    "build":  "node scripts/turbo-or-fallback.mjs run build --filter=@tsc/api...",
                    "build:api":  "pnpm --filter @tsc/api... run build",
                    "build:fallback":  "pnpm --filter @tsc/api... run build",
                    "verify:dist":  "node scripts/verify-workspace-dist.mjs",
                    "deploy:api":  "node scripts/create-deploy-bundle.mjs",
                    "verify:deploy":  "node scripts/verify-deploy-bundle.mjs",
                    "start:prod:railway":  "node scripts/railway-start.mjs",
                    "build:all":  "pnpm -r run build",
                    "dev":  "node scripts/turbo-or-fallback.mjs run dev --parallel --filter=@tsc/api --filter=@tsc/community",
                    "lint":  "node scripts/turbo-or-fallback.mjs run lint",
                    "lint:fallback":  "pnpm -r run lint",
                    "typecheck":  "node scripts/turbo-or-fallback.mjs run typecheck",
                    "typecheck:fallback":  "pnpm -r run typecheck",
                    "test":  "node scripts/turbo-or-fallback.mjs run test",
                    "test:fallback":  "pnpm -r run test",
                    "test:e2e":  "pnpm --filter @tsc/e2e test",
                    "test:e2e:coreknot":  "pnpm --filter @tsc/e2e test:coreknot",
                    "test:e2e:website":  "pnpm --filter @tsc/e2e test:website:audit",
                    "test:e2e:community":  "pnpm --filter @tsc/e2e test:community:audit",
                    "test:e2e:audit":  "pnpm --filter @tsc/e2e test:coreknot:audit && pnpm --filter @tsc/e2e test:frontend:audit",
                    "test:migration:api-smoke":  "pnpm --filter @tsc/e2e test:migration:api-smoke",
                    "ci":  "node scripts/turbo-or-fallback.mjs run lint typecheck test build",
                    "ci:fallback":  "pnpm -r run lint \u0026\u0026 pnpm -r run typecheck \u0026\u0026 pnpm -r run test \u0026\u0026 pnpm --filter @tsc/api... run build",
                    "setup":  "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
                    "setup:unix":  "bash scripts/setup.sh",
                    "start":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target community",
                    "start:community":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target community",
                    "start:coreknot":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target coreknot",
                    "start:coreknot:single":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target coreknot -SingleTerminal",
                    "start:website":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target website",
                    "start:all":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target all",
                    "start:community:nodocker":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target community -SkipInfra",
                    "start:coreknot:nodocker":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target coreknot -SkipInfra -KillPorts",
                    "start:website:nodocker":  "powershell -ExecutionPolicy Bypass -File scripts/start-stack.ps1 -Target website -SkipInfra",
                    "start:infra":  "powershell -ExecutionPolicy Bypass -File scripts/start-infra.ps1",
                    "start:unix":  "bash scripts/start-stack.sh community",
                    "stop":  "powershell -ExecutionPolicy Bypass -File scripts/stop.ps1",
                    "infra:up":  "powershell -ExecutionPolicy Bypass -File scripts/start-infra.ps1",
                    "infra:down":  "docker compose down",
                    "dev:api":  "pnpm --filter @tsc/api dev",
                    "dev:community":  "pnpm --filter @tsc/community dev",
                    "dev:coreknot":  "pnpm --filter @tsc/coreknot-client dev",
                    "dev:coreknot:server":  "pnpm --filter @tsc/coreknot-server dev",
                    "start:coreknot:workers":  "pnpm --filter @tsc/coreknot-server start:workers",
                    "dev:coreknot:stack":  "pnpm exec concurrently -n server,client -c green,cyan \"pnpm dev:coreknot:server\" \"pnpm dev:coreknot\"",
                    "migrate:coreknot:mongo":  "node scripts/coreknot/migrate-mongo-to-tsc.mjs --dry-run",
                    "migrate:coreknot:p0":  "node scripts/migrations/coreknot/run-p0.mjs",
                    "migrate:coreknot:p0:execute":  "node scripts/migrations/coreknot/run-p0.mjs --execute",
                    "migrate:coreknot:p1":  "node scripts/migrations/coreknot/run-p1.mjs",
                    "migrate:coreknot:p1:execute":  "node scripts/migrations/coreknot/run-p1.mjs --execute",
                    "sync:coreknot:prod-local":  "pnpm --filter @tsc/coreknot-server sync-db",
                    "dev:website":  "pnpm --filter @tsc/website dev",
                    "dev:stack:community":  "powershell -ExecutionPolicy Bypass -File scripts/dev-community.ps1",
                    "dev:stack:coreknot":  "powershell -ExecutionPolicy Bypass -File scripts/dev-coreknot.ps1",
                    "dev:stack:website":  "powershell -ExecutionPolicy Bypass -File scripts/dev-website.ps1",
                    "kill:port":  "powershell -ExecutionPolicy Bypass -File scripts/kill-port.ps1",
                    "db:generate":  "pnpm --filter @tsc/database prisma:generate",
                    "db:validate":  "pnpm --filter @tsc/database prisma:validate",
                    "db:push":  "pnpm --filter @tsc/database exec prisma db push",
                    "db:migrate":  "pnpm --filter @tsc/database exec prisma migrate dev",
                    "db:studio":  "pnpm --filter @tsc/database exec prisma studio",
                    "seed:dev-user":  "pnpm --filter @tsc/database seed:dev-user",
                    "kill:ports":  "powershell -ExecutionPolicy Bypass -File scripts/kill-all-dev-ports.ps1",
                    "clean:ports":  "pnpm kill:ports",
                    "sweep:local":  "powershell -ExecutionPolicy Bypass -File scripts/sweep-local.ps1",
                    "sweep:prod":  "powershell -ExecutionPolicy Bypass -File scripts/sweep-prod.ps1",
                    "start:prod":  "pnpm --filter @tsc/api start:prod",
                    "migrate:coreknot:count-parity":  "node e2e/migration/count-parity.mjs",
                    "migrate:coreknot:verify-cutover":  "node scripts/migrations/coreknot/verify-cutover.mjs",
                    "migrate:coreknot:verify-cutover:ping":  "node scripts/migrations/coreknot/verify-cutover.mjs --ping",
                    "coreknot:migrate:export-users":  "node scripts/migrations/coreknot/export-users-json.mjs",
                    "coreknot:migrate:seed-auth":  "node scripts/migrations/coreknot/load-legacy-auth.mjs"
                },
    "devDependencies":  {
                            "concurrently":  "^9.1.2",
                            "@eslint/js":  "^9.17.0",
                            "@turbo/windows-64":  "2.9.18",
                            "@typescript-eslint/eslint-plugin":  "^8.18.0",
                            "@typescript-eslint/parser":  "^8.18.0",
                            "eslint":  "^9.17.0",
                            "turbo":  "^2.3.0",
                            "typescript":  "^5.7.0",
                            "typescript-eslint":  "^8.18.0",
                            "vitest":  "^3.0.0"
                        },
    "packageManager":  "pnpm@9.15.0",
    "pnpm":  {
                 "overrides":  {
                                   "fast-check":  "3.22.0"
                               }
             }
}
