# TSC Platform — Environment Template
# Split into per-app files for local dev. See docs/architecture/ENV-STANDARD.md

# ============ PLATFORM API (apps/api/.env) ============
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Auth — production: real Clerk keys, TSC_AUTH_STUB unset/false
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
TSC_AUTH_STUB=true
TSC_STUB_USER_ID=stub-dev-user
TSC_ADMIN_USER_IDS=
TSC_PUBLIC_URL=http://localhost:3000

# Observability (optional locally — see apps/api/src/observability/README.md)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
BETTERSTACK_HEARTBEAT_URL=

# Search / storage (optional)
TYPESENSE_HOST=
TYPESENSE_API_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ============ TSC COMMUNITY (apps/community/.env.local) ============
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_AUTH_STUB=true
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ============ TSC WEBSITE (apps/website/.env.local) ============
NEXT_PUBLIC_TSC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3002
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_AUTH_STUB=true

# Production overrides (Vercel dashboard):
# NEXT_PUBLIC_API_URL=https://api.theshakticollective.in/api
# NEXT_PUBLIC_TSC_API_URL=https://api.theshakticollective.in/api
