# PostgreSQL
# Local Docker: postgresql://postgres:postgres@localhost:5432/tsc_community
# Neon (no Docker): postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community

# Redis (BullMQ queues — optional for basic dev)
# Local Docker: redis://localhost:6379
# Production (Railway): set REDIS_URL in service Variables — do not commit real URL
# Upstash: rediss://default:YOUR_TOKEN@YOUR-ENDPOINT.upstash.io:6379
# Railway Redis plugin: redis://default:<password>@<host>.railway.internal:<port>
REDIS_URL=redis://localhost:6379
# REDIS_URL=
# REDIS_URL=<Railway or Upstash Redis URL>

# NestJS API
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api
# Comma-separated browser origins for Community (:3000), CoreKnot (:3001), Website (:3002)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Auth stub — local dev only (ignored when NODE_ENV=production)
# API auto-stubs when true OR CLERK_SECRET_KEY is unset/contains REPLACE_ME
TSC_AUTH_STUB=true
NEXT_PUBLIC_AUTH_STUB=true
TSC_STUB_USER_ID=stub-dev-user

# Clerk — shared SSO across Community, CoreKnot, Website, and API JWT validation
# Create one Clerk application; use the same keys in every frontend + API.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Community + Website (Next.js) routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# CoreKnot (Vite) — same publishable key, VITE_ prefix
VITE_CLERK_PUBLISHABLE_KEY=

# Production multi-domain SSO (optional — satellite apps redirect sign-in to primary domain)
# NEXT_PUBLIC_CLERK_IS_SATELLITE=true
# NEXT_PUBLIC_CLERK_DOMAIN=community.theshakticollective.in
# CLERK_SIGN_IN_URL=https://theshakticollective.in/sign-in

# Platform admin Clerk user IDs (comma-separated) — grants API admin role
TSC_ADMIN_USER_IDS=

# Skip Docker infra when virtualization unavailable (auto-detected if docker.exe fails)
# TSC_SKIP_DOCKER=true

# Open Chrome/Edge/Opera (system default) when stack starts — not Cursor Simple Browser
TSC_OPEN_BROWSER=true

# Frontend → API URLs (no trailing slash on base; SDK adds paths)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TSC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
VITE_TSC_API_URL=http://localhost:4000/api
VITE_API_URL=http://localhost:4000

# Optional — CoreKnot sync (when legacy server is running)
# COREKNOT_SYNC_URL=http://localhost:3001/api/sync
# COREKNOT_SYNC_SECRET=

# Optional — payment provider keys (stubs used when unset)
# STRIPE_KEY=
# RAZORPAY_KEY=
# CASHFREE_KEY=

# Optional — public URLs for links in emails / passports
# TSC_PUBLIC_URL=http://localhost:3000

# PostHog (optional — analytics)
# API: POSTHOG_PROJECT_TOKEN or POSTHOG_API_KEY + POSTHOG_HOST (no-ops when unset)
# Next.js frontends: NEXT_PUBLIC_POSTHOG_KEY + NEXT_PUBLIC_POSTHOG_HOST
# CoreKnot: VITE_POSTHOG_KEY + VITE_POSTHOG_HOST
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional — error tracking)
# API: SENTRY_DSN | Next.js: NEXT_PUBLIC_SENTRY_DSN | CoreKnot: VITE_SENTRY_DSN
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
VITE_SENTRY_DSN=

# BetterStack (optional — uptime heartbeat for tsc-api)
BETTERSTACK_HEARTBEAT_URL=
# BETTERSTACK_SOURCE_TOKEN=  # log drain — wire when log shipping is added

# Typesense (optional — search; production Railway)
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PROTOCOL=https
TYPESENSE_PORT=443

# Cloudflare R2 (optional — media storage; production Railway)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Auto-free dev ports 3000-3002,4000 before start-stack (set false to disable)
TSC_KILL_PORTS=true
