# TSC Platform — shared local infrastructure (copy to `.env`, never commit secrets)
# Per-app templates: see ENVIRONMENT_GUIDE.md and each app’s `.env.example`.

# --- Postgres (Prisma — all backends + `pnpm db:*`) ---
# Local Docker: postgresql://postgres:postgres@localhost:5432/tsc_community
# Neon: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community

# --- Redis (BullMQ — optional for basic dev) ---
# Local Docker: redis://localhost:6379
# Upstash (no Docker): rediss://default:TOKEN@YOUR-ENDPOINT.upstash.io:6379
# REST helpers (optional — not used by BullMQ): UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
# Empty = API stub queue mode; CoreKnot mail campaigns need Redis + worker process
REDIS_URL=redis://localhost:6379
# REDIS_URL=

# --- Dev stack tooling (read by scripts/start-stack.ps1, stack-common.ps1) ---
# Skip Docker when virtualization unavailable (auto-detected if docker fails)
# TSC_SKIP_DOCKER=true
# Auto-free dev ports 3000-3002,4000,5000 before start-stack
TSC_KILL_PORTS=true
# Open system browser when stack starts (not Cursor Simple Browser)
TSC_OPEN_BROWSER=true

# --- App-specific env (do NOT duplicate here) ---
# apps/api/.env.example              — NestJS TSC API (:4000)
# apps/community/.env.example         — Next.js Community → copy to .env.local
# apps/website/.env.example           — Next.js Website → copy to .env.local
# apps/coreknot/server/.env.example   — CoreKnot CRM Express API (:5000)
# apps/coreknot/client/.env.example   — Vite CoreKnot client → copy to .env.local
# packages/database/.env.example      — Prisma CLI (optional; same DATABASE_URL)
