# TSC Shared Infrastructure — Environment Template

> Copy individual sections into Railway/Vercel/Neon dashboards or local `.env`.  
> Never commit filled-in secrets. See [architecture/ENV-STANDARD.md](./architecture/ENV-STANDARD.md).

# --- PostgreSQL (Neon) ---
# Local: postgresql://postgres:postgres@localhost:5432/tsc_community
# Prod: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Redis (Upstash / Railway KV / local Docker) ---
# Local: redis://localhost:6379
# Prod: rediss://default:TOKEN@endpoint.upstash.io:6379
REDIS_URL=

# --- Clerk (identity) ---
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Observability ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
BETTERSTACK_HEARTBEAT_URL=

# --- Cloudflare R2 (optional — media/finance attachments) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# --- Typesense (optional — search) ---
TYPESENSE_HOST=
TYPESENSE_API_KEY=
TYPESENSE_PROTOCOL=https
TYPESENSE_PORT=443

# --- Email (Resend) ---
RESEND_API_KEY=
