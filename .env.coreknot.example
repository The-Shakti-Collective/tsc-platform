# CoreKnot — Environment Template
# Split into server + client files. See docs/architecture/ENV-STANDARD.md

# ============ COREKNOT API (apps/coreknot/server/.env) ============
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tsc_community
REDIS_URL=redis://localhost:6379

# Legacy Mongo — REMOVE after docs/architecture/MONGO-SUNSET-REPORT.md exit criteria
MONGODB_URI=mongodb://localhost:27017/taskmaster_local
MONGODB_URI_PROD=

# Postgres cutover flags (target production profile)
# COREKNOT_POSTGRES_ENABLED=true
# COREKNOT_POSTGRES_PRIMARY=true
# COREKNOT_MONGO_REQUIRED=false
# COREKNOT_AUTH_STORE=postgres
# COREKNOT_TENANT_STORE=postgres
# COREKNOT_PROJECTS_STORE=postgres
# COREKNOT_TASKS_STORE=postgres
# COREKNOT_CRM_STORE=postgres

# Staff auth — target: Clerk; current: JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_ABSOLUTE_MAX_DAYS=30
ENCRYPTION_KEY=

# Workers (Railway 2nd service)
RUN_WORKERS=false

# URLs
FRONTEND_URL=http://localhost:3001
SERVER_URL=http://localhost:5000
# CORS_ALLOWED_ORIGINS=https://coreknot.in

# Platform API proxy (server-to-server)
# TSC_API_URL=http://localhost:4000/api

# Webhooks from TSC Website
BOOK_CALL_WEBHOOK_SECRET=
NEWSLETTER_WEBHOOK_SECRET=
ARTIST_PATH_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
POSTHOG_PROJECT_TOKEN=

# ============ COREKNOT CLIENT (apps/coreknot/client/.env.local) ============
VITE_API_URL=http://localhost:5000/api
VITE_POSTHOG_KEY=
# Production: VITE_API_URL=https://api.coreknot.in/api
