  threadId       String
  senderPersonId String
  body           String
  metadata       Json     @default("{}")
  sentAt         DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sender       Person        @relation("MessageSender", fields: [senderPersonId], references: [id], onDelete: Cascade)

  @@index([threadId, sentAt(sort: Desc)])
  @@index([organizationId])
  @@index([senderPersonId])
}

model Notification {
  id                String                 @id @default(cuid())
  organizationId    String?
  recipientPersonId String
  type              DomainNotificationType
  title             String
  body              String?
  readAt            DateTime?
  metadata          Json                   @default("{}")
  createdAt         DateTime               @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  recipient    Person        @relation("NotificationRecipient", fields: [recipientPersonId], references: [id], onDelete: Cascade)

  @@index([recipientPersonId, readAt])
  @@index([organizationId, createdAt(sort: Desc)])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String?
  actorPersonId  String?
  entityType     String
  entityId       String
  action         AuditAction
  changes        Json        @default("{}")
  createdAt      DateTime    @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        Person?       @relation("AuditActor", fields: [actorPersonId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([actorPersonId])
}

// ── CoreKnot domain backend Phases 4–5 ──────────────────────────────────────

enum RoyaltyStatementStatus {
  draft
  pending
  reconciled
  paid
}

enum DistributionProvider {
  distrokid
  manual
  other
}

enum DistributionSubmissionStatus {
  draft
  submitted
  processing
  live
  failed
  cancelled
}

enum ContentAssetType {
  audio
  video
  image
  document
  other
}

enum ContentItemStatus {
  draft
  published
  archived
}

enum IntegrationProvider {
  google
  meta
  spotify
  youtube
  distrokid
  resend
  other
}

enum IntegrationConnectionStatus {
  disconnected
  pending
  connected
  error
}

model RoyaltyStatement {
  id             String                 @id @default(cuid())
  organizationId String
  artistId       String?
  periodStart    DateTime
  periodEnd      DateTime
  currency       String                 @default("INR")
  grossAmount    Decimal                @default(0)
  netAmount      Decimal                @default(0)
  status         RoyaltyStatementStatus @default(draft)
  source         String?
  externalId     String?
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  artist       Artist?           @relation(fields: [artistId], references: [id], onDelete: SetNull)
  lineItems    RoyaltyLineItem[]

  @@index([organizationId, periodStart])
  @@index([artistId, status])
  @@index([status])
}

model RoyaltyLineItem {
  id          String   @id @default(cuid())
  statementId String
  title       String
  platform    String?
  streams     Int?
  amount      Decimal
  currency    String   @default("INR")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  statement RoyaltyStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
}

model DistributionChannel {
  id        String               @id @default(cuid())
  artistId  String
  provider  DistributionProvider @default(distrokid)
  name      String
  isActive  Boolean              @default(true)
  config    Json                 @default("{}")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  artist      Artist                   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  submissions DistributionSubmission[]

  @@index([artistId, provider])
}

model DistributionSubmission {
  id              String                       @id @default(cuid())
  channelId       String
  releaseId       String?
  title           String
  status          DistributionSubmissionStatus @default(draft)
  upc             String?
  isrc            String?
  submittedAt     DateTime?
  liveAt          DateTime?
  externalId      String?
  providerPayload Json                         @default("{}")
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  channel DistributionChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  release Release?            @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([channelId, status])
  @@index([releaseId])
}

model ReleaseTrack {
  id          String  @id @default(cuid())
  releaseId   String
  title       String
  trackNumber Int     @default(1)
  isrc        String?
  durationSec Int?
  metadata    Json    @default("{}")

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId])
}

model ContentAsset {
  id         String           @id @default(cuid())
  artistId   String
  releaseId  String?
  title      String
  assetType  ContentAssetType @default(other)
  mimeType   String?
  storageKey String?
  url        String?
  sizeBytes  Int?
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  artist  Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  release Release? @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([artistId])
  @@index([releaseId])
}

model ContentItem {
  id          String            @id @default(cuid())
  artistId    String
  title       String
  body        String?
  status      ContentItemStatus @default(draft)
  publishedAt DateTime?
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, status])
}

model IntegrationConnection {
  id                String                      @id @default(cuid())
  organizationId    String?
  provider          IntegrationProvider
  status            IntegrationConnectionStatus @default(disconnected)
  externalAccountId String?
  scopes            String[]                    @default([])
  tokenStub         Json                        @default("{}")
  lastSyncAt        DateTime?
  metadata          Json                        @default("{}")
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([provider, status])
  @@index([organizationId])
}

model AnalyticsMetricSnapshot {
  id             String   @id @default(cuid())
  organizationId String?
  metricKey      String
  periodStart    DateTime
  periodEnd      DateTime
  value          Decimal  @default(0)
  dimensions     Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([metricKey, periodStart])
  @@index([organizationId, metricKey])
}

// ── CoreKnot legacy runtime auth (transitional — pre-Clerk cutover) ─────────
// Mirrors Mongo users/departments/tenants for local Postgres auth read path.
// Audit fragment: packages/database/prisma/coreknot-legacy-auth.prisma

model CkLegacyTenant {
  id           String   @id
  name         String
  domain       String?  @unique
  contactEmail String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departments CkLegacyDepartment[]
  users       CkLegacyStaffUser[]

  @@map("ck_legacy_tenants")
}

model CkLegacyDepartment {
  id               String   @id
  tenantId         String
  name             String
  slug             String
  color            String   @default("#3b82f6")
  sortOrder        Int      @default(0)
  signupAllowed    Boolean  @default(true)
  permissionPreset String   @default("standard")
  pagePermissions  String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant CkLegacyTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  CkLegacyStaffUser[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("ck_legacy_departments")
}

model CkLegacyStaffUser {
  id                 String    @id @default(cuid())
  mongoId            String    @unique
  tenantId           String
  departmentId       String?
  email              String    @unique
  passwordHash       String?
  name               String
  avatar             String?
  gender             String?
  dateOfBirth        DateTime?
  phone              String    @default("")
  repId              String?   @unique
  pagePermissions    String[]  @default([])
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?
  googleId           String?
  googleCalendarLinked Boolean @default(false)
  exp                Int       @default(0)
  level              Int       @default(1)
  dailyStreak        Int       @default(0)
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant     CkLegacyTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department CkLegacyDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([departmentId])
  @@index([phone])
  @@index([name])
  @@map("ck_legacy_staff_users")
}

// Wave 2 transitional store — JSON payload mirror for domains without canonical Prisma models yet.
model CkLegacyDocument {
  id         String   @id @default(cuid())
  entityType String
  mongoId    String
  tenantId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, mongoId])
  @@index([tenantId, entityType])
  @@map("ck_legacy_documents")
}
