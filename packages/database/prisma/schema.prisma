// TSC Platform — canonical merged schema (Stage 1 Step 1).
// Phase fragments retained in prisma/phase*.prisma for audit trail.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GraphEntityType {
  Artist
  Venue
  Curator
  Brand
  Agency
  Label
  Organization
  Person
  Festival
  Event
  Community
  Membership
  CreativeIdentity
  Skill
}

enum RelationshipType {
  MANAGES
  COLLABORATED_WITH
  ATTENDED
  MEMBER_OF
  PERFORMED_AT
  BOOKED_BY
  FOLLOWS
  MENTORED_BY
  SPONSORED_BY
  WORKED_WITH
  REFERRED_BY
  SIGNED_TO
  SUPPORTED
  SUBSCRIBED
  PURCHASED
  REFERRED
  HAS_SKILL
}

enum FanIntelligenceTier {
  super
  active
  casual
  dormant
}

enum BrandStatus {
  active
  pending
  archived
}

enum BrandBudgetRange {
  under_5l
  five_to_25l
  twenty_five_to_1cr
  over_1cr
  undisclosed
}

model Relationship {
  id               String           @id
  sourceEntityType GraphEntityType
  sourceEntityId   String
  targetEntityType GraphEntityType
  targetEntityId   String
  relationshipType RelationshipType
  strength         Float?
  weight           Float?
  metadata         Json             @default("{}")
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([sourceEntityType, sourceEntityId, targetEntityType, targetEntityId, relationshipType])
  @@index([sourceEntityType, sourceEntityId])
  @@index([targetEntityType, targetEntityId])
  @@index([relationshipType])
  @@index([effectiveFrom, effectiveTo])
}

model Brand {
  id          String            @id @default(cuid())
  name        String
  industry    String?
  website     String?
  city        String?
  country     String?
  logo        String?
  description String?
  budgetRange BrandBudgetRange?
  categories  String[]          @default([])
  verified    Boolean           @default(false)
  status      BrandStatus       @default(active)
  trustScore  Float?
  personId    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner         Person?       @relation("BrandOwner", fields: [personId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  deals         Deal[]
  contracts     Contract[]

  @@index([status, verified])
  @@index([industry])
  @@index([city])
  @@index([personId])
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  website   String?
  city      String?
  teamSize  Int?
  personId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact       Person?       @relation("AgencyContact", fields: [personId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  deals         Deal[]

  @@index([city])
  @@index([personId])
}

model Label {
  id        String   @id @default(cuid())
  name      String
  genre     String?
  website   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([genre])
  @@index([city])
}

enum TrustEntityType {
  Artist
  Brand
  Agency
}

model TrustSnapshot {
  id             String          @id @default(cuid())
  entityType     TrustEntityType
  entityId       String
  snapshotDate   DateTime        @default(now())
  trustScore     Float
  factors        Json            @default("{}")
  badges         String[]        @default([])
  rankPercentile Float?
  createdAt      DateTime        @default(now())

  @@unique([entityType, entityId, snapshotDate])
  @@index([entityType, entityId, snapshotDate(sort: Desc)])
  @@index([entityType, trustScore(sort: Desc)])
}

// Phase 7 Month 3 — Deal pipeline models (merged below).
enum DealStatus {
  application
  discussion
  negotiation
  agreement
  completed
  paid
}

enum RevenueTransactionType {
  expected
  received
  pending
}

enum IdentifierProvider {
  email
  phone
  instagram
  spotify
  tiktok
  twitter
  community_account
  coreknot_user
  website
  other
}

enum PersonRoleType {
  artist
  manager
  fan
  community_leader
  booker
  curator
  brand_rep
  organizer
  other
}

enum PersonRoleStatus {
  active
  inactive
  pending
}

enum IdentityMergeReason {
  manual
  auto_match
  sync_reconcile
  admin_override
}

enum ActivityAction {
  joined_community
  left_community
  registered_event
  checked_in_event
  posted_collaboration
  applied_collaboration
  applied_opportunity
  won_opportunity
  launched_opportunity
  followed_person
  unfollowed_person
  updated_profile
  created_brand
  created_agency
  created_label
  reviewed_application
  hired_artist
  deal_created
  deal_completed
  deal_paid
  purchased_product
  agent_recommendation_created
  career_actions_generated
  career_action_dismissed
  community_agent_suggestions_generated
  community_suggestion_approved
  community_suggestion_dismissed
  event_agent_insights_generated
  event_suggestion_approved
  event_suggestion_dismissed
  brand_match_run_completed
  brand_match_invite_sent
  talent_discovery_scan_completed
  talent_discovery_alert_acknowledged
  forecast_generated
  insight_action_executed
  automation_rule_evaluated
  automation_action_stubbed
  copilot_query_answered
  autonomous_workflow_started
  autonomous_workflow_step_completed
  autonomous_workflow_approved
  autonomous_workflow_completed
  autonomous_workflow_cancelled
  opportunity_generated
  opportunity_generation_published
  workspace_created
  workspace_member_added
  project_created
  task_created
  task_completed
  creative_identity_created
  creative_role_added
  skill_added
  skill_endorsed
  tracked_listing
}

enum GeneratedOpportunitySource {
  system
  brand
  community
}

enum GeneratedOpportunityStatus {
  draft
  pending_approval
  published
  dismissed
}

enum GeneratedOpportunityType {
  showcase_event
  collaboration_open_call
  grant_opportunity
}

enum ActivityVisibility {
  public
  followers
  private
}

enum CommunityMemberRole {
  Founder
  Admin
  Moderator
  Contributor
  Member
}

enum CommunityMemberStatus {
  active
  left
  banned
  pending
}

enum EventParticipationRole {
  Attendee
  Artist
  Volunteer
  Organizer
  Judge
  Speaker
}

enum EventParticipationStatus {
  registered
  checked_in
  cancelled
  no_show
}

enum CollaborationType {
  need_rapper
  need_producer
  need_guitarist
  need_videographer
  need_cover_artist
  general
}

enum CollaborationStatus {
  open
  filled
  closed
  expired
}

enum CollaborationApplicationStatus {
  applied
  accepted
  rejected
  withdrawn
}

enum OpportunityCategory {
  scholarship
  residency
  brand_deal
  festival_slot
  workshop
  collaboration
  open_call
  funding
}

enum OpportunityApplicationStatus {
  saved
  applied
  shortlisted
  won
  rejected
}

enum SyncSourceSystem {
  coreknot
  tsc
}

enum SyncEventReceiptStatus {
  processed
  duplicate
  failed
}

enum ReputationEntityType {
  Person
  Artist
  Community
}

model Person {
  id           String   @id @default(cuid())
  name         String?
  displayName  String?
  email        String?
  phone        String?
  metadata     Json     @default("{}")
  mergedIntoId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mergedInto                     Person?                     @relation("PersonMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom                     Person[]                    @relation("PersonMerge")
  profile                        PersonProfile?
  identifiers                    PersonIdentifier[]
  roles                          PersonRole[]
  mergeLogs                      IdentityMergeLog[]          @relation("MergeSurvivor")
  verificationRequests           PersonVerificationRequest[]
  activities                     Activity[]                  @relation("PersonActivities")
  following                      PersonFollow[]              @relation("PersonFollowing")
  followers                      PersonFollow[]              @relation("PersonFollowers")
  communityMemberships           CommunityMember[]
  eventParticipations            EventParticipation[]
  communityPosts                 CommunityPost[]
  collaborationsCreated          Collaboration[]             @relation("CollaborationCreator")
  collaborationApplications      CollaborationApplication[]  @relation("CollaborationApplicant")
  opportunityApplications        OpportunityApplication[]
  ecosystemCredit                EcosystemCredit?
  artist                         Artist?
  fanProfile                     FanProfile?
  artistFollows                  ArtistFollow[]
  superfanSnapshots              SuperfanSnapshot[]
  membershipSubscriptions        MembershipSubscription[]
  rewardRedemptions              RewardRedemption[]
  supportActions                 SupportAction[]
  fanPurchases                   FanPurchase[]
  agentRecommendations           AgentRecommendation[]       @relation("AgentRecommendationsForPerson")
  automationRuns                 AutomationRun[]
  brandsOwned                    Brand[]                     @relation("BrandOwner")
  agenciesLed                    Agency[]                    @relation("AgencyContact")
  bookingRequests                BookingRequest[]            @relation("BookingRequestRequester")
  payouts                        Payout[]
  ownedWorkspaces                Workspace[]                 @relation("WorkspaceOwner")
  workspaceMembers               WorkspaceMember[]
  projectMembers                 ProjectMember[]
  createdTasks                   Task[]                      @relation("TaskCreator")
  taskAssignees                  TaskAssignee[]
  taskComments                   TaskComment[]
  generatedOpportunitiesApproved GeneratedOpportunity[]      @relation("GeneratedOpportunityApprovedBy")
  creativeIdentity               CreativeIdentity?
  skillEndorsementsGiven         SkillEndorsement[]          @relation("SkillEndorsementsGiven")
  userAccount                    User?
  platformIdentity               Identity?
  organizationMemberships        OrganizationMember[]
  organizationTeamsLed           OrganizationTeam[]          @relation("OrganizationTeamLead")
  organizationTeamMemberships    OrganizationTeamMember[]
  assignedLeads                  Lead[]                      @relation("LeadAssignee")
  assignedInquiries              Inquiry[]                   @relation("InquiryAssignee")
  sentMessages                   Message[]                   @relation("MessageSender")
  notifications                  Notification[]              @relation("NotificationRecipient")
  auditLogs                      AuditLog[]                  @relation("AuditActor")

  @@index([mergedIntoId])
  @@index([email])
}

model FanProfile {
  id              String   @id @default(cuid())
  personId        String   @unique
  favoriteGenres  String[] @default([])
  favoriteArtists String[] @default([])
  cities          String[] @default([])
  engagementScore Float    @default(0)
  spendScore      Float    @default(0)
  attendanceScore Float    @default(0)
  influenceScore  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([engagementScore(sort: Desc)])
}

model ArtistFollow {
  id         String   @id @default(cuid())
  personId   String
  artistId   String
  followedAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([personId, artistId])
  @@index([artistId, followedAt(sort: Desc)])
  @@index([personId])
}

enum SuperfanTier {
  bronze
  silver
  gold
  platinum
  legend
}

model SuperfanSnapshot {
  id            String       @id @default(cuid())
  personId      String
  artistId      String?
  superfanScore Float        @default(0)
  tier          SuperfanTier @default(bronze)
  factors       Json         @default("{}")
  snapshotDate  DateTime     @db.Date
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, artistId, snapshotDate])
  @@index([personId, snapshotDate(sort: Desc)])
  @@index([artistId, superfanScore(sort: Desc)])
  @@index([artistId, tier])
}

model AudienceHealthSnapshot {
  id                String   @id @default(cuid())
  artistId          String
  snapshotDate      DateTime @db.Date
  audienceGrowth    Float    @default(0)
  audienceChurn     Float    @default(0)
  fanRetention      Float    @default(0)
  fanConversion     Float    @default(0)
  lifetimeValueStub Float    @default(0)
  metrics           Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, snapshotDate])
  @@index([artistId, snapshotDate(sort: Desc)])
  @@index([audienceGrowth(sort: Desc)])
  @@index([fanRetention(sort: Asc)])
}

model CommunityAudienceSnapshot {
  id                    String   @id @default(cuid())
  communityId           String
  snapshotDate          DateTime @db.Date
  memberGrowth          Float    @default(0)
  activeMembers         Int      @default(0)
  membershipRevenueStub Float    @default(0)
  fanGrowth             Float    @default(0)
  eventConversion       Float    @default(0)
  metrics               Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, snapshotDate])
  @@index([communityId, snapshotDate(sort: Desc)])
  @@index([memberGrowth(sort: Desc)])
}

model FanIntelligenceSnapshot {
  id              String              @id @default(cuid())
  personId        String
  artistId        String?
  engagementScore Float               @default(0)
  purchaseScore   Float               @default(0)
  attendanceScore Float               @default(0)
  influenceScore  Float               @default(0)
  loyaltyScore    Float               @default(0)
  tier            FanIntelligenceTier @default(casual)
  metadata        Json                @default("{}")
  snapshotDate    DateTime            @db.Date
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([personId, artistId, snapshotDate])
  @@index([personId, snapshotDate(sort: Desc)])
  @@index([artistId, engagementScore(sort: Desc)])
}

model PersonProfile {
  id                String   @id @default(cuid())
  personId          String   @unique
  username          String?  @unique
  slug              String   @unique
  bio               String?
  city              String?
  genres            String[] @default([])
  skills            String[] @default([])
  links             Json     @default("[]")
  verificationLevel Int      @default(0)
  reputationScore   Float?
  ecosystemScore    Float?
  adminVerified     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([username])
}

model PersonVerificationRequest {
  id        String   @id @default(cuid())
  personId  String
  type      String
  status    String   @default("pending")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, type, status])
}

model PersonIdentifier {
  id           String             @id @default(cuid())
  personId     String
  provider     IdentifierProvider
  externalId   String
  normalizedId String?
  verified     Boolean            @default(false)
  primary      Boolean            @default(false)
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([personId])
  @@index([provider, normalizedId])
}

model PersonRole {
  id         String           @id @default(cuid())
  personId   String
  role       PersonRoleType
  status     PersonRoleStatus @default(active)
  entityType String?
  entityId   String?
  metadata   Json?
  assignedAt DateTime         @default(now())
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, status])
  @@index([role, entityType, entityId])
}

model IdentityMergeLog {
  id                  String              @id @default(cuid())
  survivorPersonId    String
  mergedPersonId      String
  reason              IdentityMergeReason
  matchSignals        Json?
  conflictResolutions Json?
  mergedBy            String?
  metadata            Json?
  createdAt           DateTime            @default(now())

  survivorPerson Person @relation("MergeSurvivor", fields: [survivorPersonId], references: [id], onDelete: Cascade)

  @@index([survivorPersonId])
  @@index([mergedPersonId])
}

model PersonFollow {
  id                String   @id @default(cuid())
  followerPersonId  String
  followingPersonId String
  createdAt         DateTime @default(now())

  follower  Person @relation("PersonFollowing", fields: [followerPersonId], references: [id], onDelete: Cascade)
  following Person @relation("PersonFollowers", fields: [followingPersonId], references: [id], onDelete: Cascade)

  @@unique([followerPersonId, followingPersonId])
  @@index([followerPersonId])
  @@index([followingPersonId])
}

model Activity {
  id            String             @id @default(cuid())
  actorPersonId String
  action        ActivityAction
  targetType    String
  targetId      String
  metadata      Json               @default("{}")
  timestamp     DateTime           @default(now())
  visibility    ActivityVisibility @default(public)

  actor Person @relation("PersonActivities", fields: [actorPersonId], references: [id], onDelete: Cascade)

  @@index([actorPersonId, timestamp(sort: Desc)])
  @@index([targetType, targetId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

model Artist {
  id          String   @id @default(cuid())
  personId    String?  @unique
  name        String
  displayName String?
  slug        String   @unique
  bio         String?
  photoUrl    String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  person                  Person?                  @relation(fields: [personId], references: [id], onDelete: SetNull)
  passport                ArtistPassport?
  followers               ArtistFollow[]
  communities             Community[]
  events                  Event[]
  deals                   Deal[]
  applications            OpportunityApplication[]
  audienceHealthSnapshots AudienceHealthSnapshot[]
  artistHealthSnapshots   ArtistHealthSnapshot[]
  commerceProducts        CommerceProduct[]
  commerceExperiences     CommerceExperience[]
  agentRecommendations    AgentRecommendation[]
  bookingRequests         BookingRequest[]
  contracts               Contract[]
  payouts                 Payout[]
  inquiries               Inquiry[]
  gigs                    Gig[]
  releases                Release[]
  contentAssets           ContentAsset[]
  contentItems            ContentItem[]
  distributionChannels    DistributionChannel[]
  royaltyStatements       RoyaltyStatement[]

  @@index([personId])
}

model ArtistPassport {
  id                      String    @id @default(cuid())
  artistId                String    @unique
  slug                    String    @unique
  isPublic                Boolean   @default(false)
  showHealthScore         Boolean   @default(true)
  showCommunityScore      Boolean   @default(true)
  showActivityScore       Boolean   @default(true)
  showOpportunityHistory  Boolean   @default(false)
  showCareerGraph         Boolean   @default(true)
  headline                String?
  bio                     String?
  photoUrl                String?
  links                   Json      @default("[]")
  cachedEcosystemScore    Float?
  ecosystemScoreUpdatedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([isPublic, slug])
}

model Venue {
  id       String  @id @default(cuid())
  name     String
  city     String?
  capacity Int?

  events          Event[]
  bookingRequests BookingRequest[]
}

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  city        String?
  genres      String[] @default([])
  artistId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artist             Artist?                         @relation(fields: [artistId], references: [id], onDelete: SetNull)
  members            CommunityMember[]
  posts              CommunityPost[]
  snapshots          CommunityIntelligenceSnapshot[]
  audienceSnapshots  CommunityAudienceSnapshot[]
  membershipPrograms Membership[]
  commerceProducts   CommerceProduct[]
  automationRuns     AutomationRun[]

  @@index([city])
}

enum MembershipBenefit {
  early_access
  private_events
  meetups
  discounts
  exclusive_content
}

enum MembershipProgramTier {
  standard
  plus
  premium
  circle
  collective
}

enum MembershipSubscriptionStatus {
  active
  cancelled
  expired
  pending
}

model Membership {
  id          String                @id @default(cuid())
  communityId String
  name        String
  slug        String
  price       Float                 @default(0)
  currency    String                @default("INR")
  tier        MembershipProgramTier @default(standard)
  benefits    MembershipBenefit[]   @default([])
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  community     Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  subscriptions MembershipSubscription[]

  @@unique([communityId, slug])
  @@index([communityId, isActive])
}

model MembershipSubscription {
  id           String                       @id @default(cuid())
  membershipId String
  personId     String
  status       MembershipSubscriptionStatus @default(active)
  startedAt    DateTime                     @default(now())
  expiresAt    DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  person     Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([membershipId, personId])
  @@index([personId, status])
  @@index([membershipId, status])
}

enum SupportTargetType {
  Artist
  Community
  Event
}

enum SupportActionType {
  buy_ticket
  buy_membership
  buy_workshop
  buy_experience
  general_support
}

enum SupportActionStatus {
  recorded
  pending_payment
}

model SupportAction {
  id                String              @id @default(cuid())
  supporterPersonId String
  targetType        SupportTargetType
  targetId          String
  actionType        SupportActionType
  amount            Float?
  currency          String?             @default("INR")
  status            SupportActionStatus @default(recorded)
  metadata          Json                @default("{}")
  createdAt         DateTime            @default(now())

  supporter    Person        @relation(fields: [supporterPersonId], references: [id], onDelete: Cascade)
  fanPurchases FanPurchase[]

  @@index([supporterPersonId, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([targetType, targetId, actionType])
}

enum CommerceCatalogStatus {
  active
  inactive
  sold_out
}

enum CommerceProductType {
  physical_merch
  sample_pack
  digital_download
}

enum CommerceExperienceType {
  vip_meet_greet
  workshop
  backstage
  community_pass
}

enum FanPurchaseProductType {
  ticket
  merch
  experience
}

enum FanPurchaseStatus {
  recorded
  pending_payment
}

model Ticket {
  id        String                @id @default(cuid())
  eventId   String
  name      String
  price     Float
  currency  String                @default("INR")
  quantity  Int
  soldCount Int                   @default(0)
  status    CommerceCatalogStatus @default(active)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, status])
}

model CommerceProduct {
  id          String                @id @default(cuid())
  artistId    String?
  communityId String?
  name        String
  type        CommerceProductType
  price       Float
  currency    String                @default("INR")
  inventory   Int?
  soldCount   Int                   @default(0)
  status      CommerceCatalogStatus @default(active)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  artist    Artist?    @relation(fields: [artistId], references: [id], onDelete: SetNull)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  @@index([artistId, status])
  @@index([communityId, status])
  @@index([type, status])
}

model CommerceExperience {
  id          String                 @id @default(cuid())
  artistId    String
  name        String
  type        CommerceExperienceType
  price       Float
  currency    String                 @default("INR")
  slots       Int
  bookedCount Int                    @default(0)
  status      CommerceCatalogStatus  @default(active)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, status])
  @@index([type, status])
}

model FanPurchase {
  id              String                 @id @default(cuid())
  personId        String
  productType     FanPurchaseProductType
  productId       String
  amount          Float
