// Phase 6.5 Sprint 2 — Community Membership Engine — merge into schema.prisma

enum CommunityMemberRole {
  Founder
  Moderator
  Member
  Contributor
}

enum CommunityMemberStatus {
  active
  left
  banned
  pending
}

model CommunityMember {
  id          String                @id @default(cuid())
  communityId String
  personId    String
  role        CommunityMemberRole   @default(Member)
  status      CommunityMemberStatus @default(active)
  joinedAt    DateTime              @default(now())
  leftAt      DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([communityId, personId])
  @@index([communityId, status])
  @@index([personId, status])
}

