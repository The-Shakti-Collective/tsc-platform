// Phase 7 Month 4 — Trust Scores + Recommendation V2 (merge into schema.prisma)

enum TrustEntityType {
  Artist
  Brand
  Agency
}

model TrustSnapshot {
  id           String          @id @default(cuid())
  entityType   TrustEntityType
  entityId     String
  snapshotDate DateTime        @default(now())
  trustScore   Float
  factors      Json            @default("{}")
  badges       String[]        @default([])
  rankPercentile Float?
  createdAt    DateTime        @default(now())

  @@unique([entityType, entityId, snapshotDate])
  @@index([entityType, entityId, snapshotDate(sort: Desc)])
  @@index([entityType, trustScore(sort: Desc)])
}

